{
  "name": "bailefun",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "email:build": "email build",
    "email:dev": "email dev",
    "email:export": "email export",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "predeploy": "medusa db:migrate",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@getbrevo/brevo": "^3.0.4",
    "@medusajs/admin-sdk": "2.14.2",
    "@medusajs/cli": "2.14.2",
    "@medusajs/framework": "2.14.2",
    "@medusajs/icons": "^2.14.2",
    "@medusajs/js-sdk": "2.14.2",
    "@medusajs/medusa": "2.14.2",
    "@medusajs/types": "2.14.2",
    "@medusajs/ui": "^4.1.5",
    "@mikro-orm/core": "6.4.16",
    "@mikro-orm/knex": "6.4.16",
    "@mikro-orm/migrations": "6.4.16",
    "@mikro-orm/postgresql": "6.4.16",
    "@react-email/components": "^1.0.11",
    "awilix": "^8.0.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.14.2",
    "@mikro-orm/cli": "6.4.16",
    "@react-email/preview-server": "5.2.5",
    "@swc/core": "1.15.10",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^5.2.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@medusajs/draft-order": "npm:@medusajs/types@latest"
  }
}